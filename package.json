{
  "name": "rebuildproject",
  "version": "0.3.0",
  "description": "把本地代码反推成一份可执行的搭建手册——按层级一步一步教你重建项目",
  "keywords": [
    "ai",
    "documentation",
    "tutorial",
    "rebuild",
    "code-to-docs",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "rebuildproject": "bin/rebuildproject.js"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node bin/rebuildproject.js",
    "prepare": "tsup"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@inquirer/prompts": "^7.2.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "handlebars": "^4.7.8",
    "ignore": "^6.0.2",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
